# ─── private planning artefacts — local only ───
.planning/

# ─── OS / editor ───
.DS_Store
*.swp
.idea/
.vscode/

# ─── language build/runtime ───
# The compiled daemon binary (the CI e2e/release jobs build it as
# ./ocu-controld; a local build must never enter the tree).
/ocu-controld
# The compiled occ operator CLI binary (local build artifact).
/occ
*.bin

# Property-test (rapid) failure corpus — regenerated on every failing run,
# never source. Keep it out of the tree so a transient local failure can't
# leak a .fail file into a commit.
testdata/rapid/
**/testdata/rapid/

# Coverage profiles — build artifacts produced by `go test -coverprofile`,
# never source (CI uploads them as run artifacts).
cover.out
*.coverprofile
__pycache__/
*.pyc
.venv/
dist/
build/
.env
.env.*
!.env.example

# ─── dev secrets — local only, never staged ───
# `make dev-secrets` materializes the local Storage-JWT signing key here so the
# first-run quickstart and the compose default mount source boot. A dev key must
# never enter the tree (gitleaks/trufflehog CI would block it anyway); ignore the
# whole dir, root-anchored so it matches the exact compose default path. Production
# provisions the signing key out of band.
/deploy/dev-secrets/

# ─── local-only Claude Code instructions ───
CLAUDE.local.md
